                <div class="text-xs font-semibold text-zinc-500 uppercase tracking-wider mt-6 mb-3">Testing & CLI</div>
                <a href="#testing" class="block px-3 py-2 rounded-lg text-sm text-zinc-400 hover:text-emerald-400 transition">Testing</a>
