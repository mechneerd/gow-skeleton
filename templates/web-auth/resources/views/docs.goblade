            </div>
        </aside>

        <!-- Content -->
        <main class="content flex-1 lg:ml-64 max-w-4xl px-8 py-12">

            <h1 id="installation" class="text-white">Installation</h1>

            <h2>Quick Install</h2>
            <p><strong>macOS / Linux</strong></p>
            <pre><code>curl -sSfL https://raw.githubusercontent.com/mechneerd/gow/main/install.sh | sh</code></pre>

            <p><strong>Windows (PowerShell)</strong></p>
            <pre><code>iwr -useb https://raw.githubusercontent.com/mechneerd/gow/main/install.ps1 | iex</code></pre>

            <p>After installation:</p>
            <pre><code>gow --version</code></pre>

            <h2>Create a New Project</h2>
            <pre><code># Interactive wizard
gow new myblog

# Non-interactive with defaults
gow new myblog --yes

# REST API with PostgreSQL
gow new myapi --api --yes --db=postgres

# Web app with authentication
gow new myapp --auth --yes

# Minimal website
gow new mysite --minimal --yes</code></pre>

            <h2>Run the Application</h2>
            <pre><code>cd myblog
gow serve
# or
go run main.go</code></pre>
            <p>Visit <code>http://localhost:8080</code>.</p>


            <h1 id="configuration" class="text-white">Configuration</h1>

            <p>GoW loads configuration from <code>.env</code> files and environment variables.</p>

            <h2>Environment Variables</h2>
            <pre><code>APP_NAME=MyApp
APP_ENV=local
APP_PORT=8080
APP_KEY=base64:your-secret-key

DB_CONNECTION=sqlite
DB_DATABASE=database.sqlite
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USERNAME=root
DB_PASSWORD=

CACHE_DRIVER=memory
SESSION_DRIVER=file
QUEUE_DRIVER=sync</code></pre>

            <h2>Accessing Configuration</h2>
            <pre><code>import "github.com/mechneerd/gow/config"

cfg := config.NewRepository(".")

// Get string value
name := cfg.Get("APP_NAME", "MyApp")

// Get typed values
port := cfg.GetInt("APP_PORT", 8080)
debug := cfg.GetBool("APP_DEBUG", false)</code></pre>


            <h1 id="directory-structure" class="text-white">Directory Structure</h1>

            <pre><code>myapp/
├── app/
│   ├── Http/
│   │   ├── Controllers/
│   │   │   └── Auth/
│   │   └── Middleware/
│   ├── Livewire/
│   └── Models/
├── bootstrap/
│   └── app.go
├── config/
│   ├── app.go
│   ├── auth.go
│   └── database.go
├── database/
│   ├── migrations/
│   ├── seeders/
│   └── factory/
├── public/
│   └── js/
├── resources/
│   └── views/
│       ├── welcome.goblade
│       └── components/
├── routes/
│   ├── web.go
│   └── api.go
├── storage/
├── .env
├── go.mod
└── main.go</code></pre>


            <h1 id="application-lifecycle" class="text-white">Application Lifecycle</h1>

            <pre><code>// main.go
package main

import (
    "myapp/routes"
    "myapp/bootstrap"
)

func main() {
    routes.RegisterWebRoutes()
    routes.RegisterAPIRoutes()

    app := bootstrap.NewApplication()
    app.Serve()
}</code></pre>


            <h1 id="service-providers" class="text-white">Service Providers</h1>

            <p>Service providers register services into the container.</p>

            <pre><code>package myprovider

import "github.com/mechneerd/gow/foundation"

type ServiceProvider struct {
    foundation.BaseServiceProvider
}

func (p *ServiceProvider) Register(app *foundation.Application) {
    app.Singleton((*MyService)(nil), func() *MyService {
        return &MyService{}
    })
}

func (p *ServiceProvider) Boot(app *foundation.Application) {
    // Called after all providers are registered
}</code></pre>


            <h1 id="ioc-container" class="text-white">IoC Container</h1>

            <pre><code>import "github.com/mechneerd/gow/container"

c := container.New()

// Bind
c.Bind((*Logger)(nil), func() Logger { return &FileLogger{} })

// Singleton
c.Singleton((*Database)(nil), func() *Database { return connectDB() })

// Resolve with generics
logger, err := container.Make[Logger](c)</code></pre>

            <h2>Contextual Bindings</h2>
            <pre><code>c.When((*PhotoController)(nil)).
    Needs((*Filesystem)(nil)).
    Give(func() *Filesystem { return NewS3Filesystem() })</code></pre>

            <h2>Struct Injection</h2>
            <pre><code>type UserController struct {
    DB    *orm.DB    `inject:""`
    Cache cache.Store `inject:""`
}</code></pre>


            <h1 id="routing" class="text-white">Routing</h1>

            <pre><code>import "github.com/mechneerd/gow/routing"

router := routing.NewRouter()

router.Get("/users", listUsers)
router.Post("/users", createUser)
router.Put("/users/{id}", updateUser)
router.Delete("/users/{id}", deleteUser)</code></pre>

            <h2>Named Routes</h2>
            <pre><code>route := router.Get("/dashboard", dashboardHandler)
router.SetName(route, "dashboard")</code></pre>

            <h2>Reading Route Params</h2>
            <pre><code>func showUser(w http.ResponseWriter, r *http.Request) error {
    params := r.Context().Value(routing.ParamsKey).(map[string]string)
    id := params["id"]
    return nil
}</code></pre>


            <h1 id="route-groups" class="text-white">Route Groups</h1>

            <pre><code>router.Group("/api", func(r *routing.Router) {
    r.Get("/users", apiListUsers)
    r.Post("/users", apiCreateUser)
})</code></pre>

            <h2>With Middleware</h2>
            <pre><code>router.Group("/admin", func(r *routing.Router) {
    r.Use(authMiddleware)
    r.Use(roleMiddleware("admin"))
    r.Get("/dashboard", adminDashboard)
})</code></pre>


            <h1 id="route-model-binding" class="text-white">Route Model Binding</h1>

            <pre><code>router.Get("/users/{user}", func(w http.ResponseWriter, r *http.Request) error {
    user, ok := routing.Model[models.User](r, "user")
    if !ok {
        return response.Error(w, 404, "User not found")
    }
    return response.JSON(w, 200, user)
})</code></pre>


            <h1 id="resource-controllers" class="text-white">Resource Controllers</h1>

            <pre><code>// Creates: index, create, store, show, edit, update, destroy
router.Resource("posts", &PostController{})

// Creates: index, store, show, update, destroy (no create/edit)
router.ApiResource("photos", &PhotoController{})</code></pre>


            <h1 id="middleware" class="text-white">Middleware</h1>

            <h2>Creating Middleware</h2>
            <pre><code>package middleware

func RateLimit(next http.Handler) http.Handler {
    return http.HandlerFunc(func(w http.ResponseWriter, r *http.Request) {
        if isRateLimited(r) {
            http.Error(w, "Too Many Requests", 429)
            return
        }
        next.ServeHTTP(w, r)
    })
}</code></pre>

            <h2>Available Middleware</h2>
            <table>
                <thead><tr><th>Middleware</th><th>Description</th></tr></thead>
                <tbody>
                    <tr><td><code>auth</code></td><td>Checks authentication status</td></tr>
                    <tr><td><code>cors</code></td><td>Cross-Origin Resource Sharing headers</td></tr>
                    <tr><td><code>csrf</code></td><td>CSRF token validation</td></tr>
                    <tr><td><code>session</code></td><td>Loads/saves session data</td></tr>
                    <tr><td><code>throttle</code></td><td>Rate limiting using cache</td></tr>
                    <tr><td><code>trim_strings</code></td><td>Trims whitespace from form values</td></tr>
                    <tr><td><code>security_headers</code></td><td>X-Frame-Options, X-Content-Type-Options, etc.</td></tr>
                    <tr><td><code>recovery</code></td><td>Recovers from panics</td></tr>
                </tbody>
            </table>


            <h1 id="query-builder" class="text-white">Query Builder</h1>

            <pre><code>b := query.NewBuilder(conn, dialect)

// Select
rows, err := b.Table("users").
    Select("name", "email").
    Where("age", ">", 18).
    OrWhere("role", "=", "admin").
    WhereIn("status", []any{"active", "pending"}).
    OrderBy("name", "ASC").
    Limit(10).
    Get()

// Joins
rows, err := b.Table("users").
    Join("posts", "users.id", "=", "posts.user_id").
    Where("users.active", "=", true).
    Get()

// Aggregates
count, _ := b.Table("users").Count("")
maxAge, _ := b.Table("users").Max("age")

// Insert
result, _ := b.Table("users").Insert(map[string]any{
    "name": "John", "email": "john@example.com",
})

// Conditional Clauses
b.Table("users").
    When(isAdmin, func(b *query.Builder) {
        b.Where("role", "=", "admin")
    }).
    Get()</code></pre>


            <h1 id="orm" class="text-white">ORM (Goquent)</h1>

            <h2>Defining Models</h2>
            <pre><code>type User struct {
    orm.Model
    Name     string     `db:"name"`
    Email    string     `db:"email"`
    Password string     `db:"password"`
    DeletedAt *time.Time `db:"deleted_at" gow:"softDelete"`
}

func (User) TableName() string { return "users" }</code></pre>

            <h2>CRUD Operations</h2>
            <pre><code>q := orm.NewQuery[User](db)

user, _ := q.Find(1)
user, _ := q.Where("email", "=", "john@example.com").First()
users, _ := q.Where("active", "=", true).Get()

q.Insert(&User{Name: "John"})
q.Update(&user)
q.Save(&user)    // Insert or Update
q.Delete(&user)</code></pre>

            <h2>Soft Deletes</h2>
            <pre><code>users, _ := q.WithTrashed().Get()     // Include soft-deleted
users, _ := q.OnlyTrashed().Get()    // Only soft-deleted
q.Restore(user)                       // Restore
q.ForceDelete(user)                   // Permanent delete</code></pre>

            <h2>Eager Loading</h2>
            <pre><code>users, _ := q.With("Posts", "Profile").Get()
users, _ := q.With("Posts.Comments").Get()</code></pre>

            <h2>Relationships</h2>
            <pre><code>type User struct {
    orm.Model
    Posts    []Post    `gow:"hasMany"`
    Profile  *Profile  `gow:"hasOne"`
    Roles    []Role    `gow:"belongsToMany"`
}

type Post struct {
    orm.Model
    UserID uint  `db:"user_id"`
    User   *User `gow:"belongsTo"`
}</code></pre>

            <h2>Lifecycle Hooks</h2>
            <pre><code>func (u *User) BeforeCreate() error {
    hashed, err := bcrypt.GenerateFromPassword([]byte(u.Password), bcrypt.DefaultCost)
    if err != nil { return err }
    u.Password = string(hashed)
    return nil
}</code></pre>
            <p>Available hooks: <code>BeforeCreate</code>, <code>AfterCreate</code>, <code>BeforeUpdate</code>, <code>AfterUpdate</code>, <code>BeforeSave</code>, <code>AfterSave</code>, <code>BeforeDelete</code>, <code>AfterDelete</code>, <code>BeforeFind</code>, <code>AfterFind</code></p>


            <h1 id="migrations" class="text-white">Migrations</h1>

            <pre><code>gow make:migration create_users_table</code></pre>

            <pre><code>package migrations

import (
    "github.com/mechneerd/gow/database/migration"
    "github.com/mechneerd/gow/database/schema"
)

type CreateUsersTable struct{}

func (CreateUsersTable) Up(m *schema.Builder) error {
    return m.Create("users", func(table *schema.Blueprint) {
        table.ID()
        table.String("name", 255)
        table.String("email", 255).Unique()
        table.String("password", 255)
        table.Boolean("is_active").Default(true)
        table.Timestamps()
    })
}

func (CreateUsersTable) Down(m *schema.Builder) error {
    return m.Drop("users")
}

func init() {
    migration.Register("2026_05_24_000001_create_users_table", CreateUsersTable{})
}</code></pre>

            <h2>Running Migrations</h2>
            <table>
                <thead><tr><th>Command</th><th>Description</th></tr></thead>
                <tbody>
                    <tr><td><code>gow migrate</code></td><td>Run all pending migrations</td></tr>
                    <tr><td><code>gow migrate:rollback</code></td><td>Rollback last migration</td></tr>
                    <tr><td><code>gow migrate:fresh</code></td><td>Drop all tables and re-run</td></tr>
                    <tr><td><code>gow migrate:refresh</code></td><td>Rollback and re-run</td></tr>
                    <tr><td><code>gow migrate:status</code></td><td>Show migration status</td></tr>
                    <tr><td><code>gow migrate:run &lt;name&gt;</code></td><td>Run specific migration</td></tr>
                </tbody>
            </table>


            <h1 id="schema-builder" class="text-white">Schema Builder</h1>

            <h2>Column Types</h2>
            <table>
                <thead><tr><th>Method</th><th>SQL Type</th></tr></thead>
                <tbody>
                    <tr><td><code>table.ID()</code></td><td>INTEGER PRIMARY KEY AUTOINCREMENT</td></tr>
                    <tr><td><code>table.String("name", 255)</code></td><td>VARCHAR(255)</td></tr>
                    <tr><td><code>table.Text("content")</code></td><td>TEXT</td></tr>
                    <tr><td><code>table.Integer("count")</code></td><td>INTEGER</td></tr>
                    <tr><td><code>table.Boolean("active")</code></td><td>BOOLEAN</td></tr>
                    <tr><td><code>table.Float("price")</code></td><td>REAL</td></tr>
                    <tr><td><code>table.Timestamps()</code></td><td>created_at, updated_at</td></tr>
                    <tr><td><code>table.SoftDeletes()</code></td><td>deleted_at</td></tr>
                    <tr><td><code>table.JSON("metadata")</code></td><td>TEXT (JSON)</td></tr>
                    <tr><td><code>table.Uuid("uuid")</code></td><td>VARCHAR(36)</td></tr>
                </tbody>
            </table>

            <h2>Column Modifiers</h2>
            <table>
                <thead><tr><th>Modifier</th><th>Description</th></tr></thead>
                <tbody>
                    <tr><td><code>.Nullable()</code></td><td>Allow NULL values</td></tr>
                    <tr><td><code>.Default(value)</code></td><td>Set default value</td></tr>
                    <tr><td><code>.Unique()</code></td><td>Add unique constraint</td></tr>
                    <tr><td><code>.Primary()</code></td><td>Mark as primary key</td></tr>
                    <tr><td><code>.Index()</code></td><td>Add index</td></tr>
                </tbody>
            </table>


            <h1 id="goblade" class="text-white">GoBlade Templates</h1>

            <pre><code>{{!-- Echo --}}
{{ $name }}
{!! $rawHtml !!}  {{-- Unescaped --}}

{{-- If/Else --}}
@if($user->active)
    <p>Active</p>
@else
    <p>Inactive</p>
@endif

{{-- Loops --}}
@foreach($users as $user)
    <p>{{ $user->name }} ({{ $loop->index }})</p>
@endforeach

{{-- CSRF --}}
<form method="POST">
    @csrf
    <input type="text" name="email">
</form>

{{-- Authorization --}}
@auth
    <p>Welcome, {{ auth()->name }}</p>
@endauth

@can('update', $post)
    <a href="/edit">Edit</a>
@endcan</code></pre>

