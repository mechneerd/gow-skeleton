<!DOCTYPE html>
<html lang="en" class="dark">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Documentation - {{ .AppName }}</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        .gradient-text { background: linear-gradient(135deg, #10b981, #3b82f6, #8b5cf6); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; }
        .sidebar a.active { color: #10b981; background: rgba(16,185,129,0.1); }
        .sidebar a:hover { color: #10b981; }
        pre code { font-family: 'JetBrains Mono', 'Fira Code', monospace; }
        .content h1 { font-size: 2rem; font-weight: 700; margin-bottom: 1rem; padding-bottom: 0.5rem; border-bottom: 1px solid #27272a; }
        .content h2 { font-size: 1.5rem; font-weight: 600; margin-top: 2.5rem; margin-bottom: 0.75rem; color: #e4e4e7; }
        .content h3 { font-size: 1.25rem; font-weight: 600; margin-top: 2rem; margin-bottom: 0.5rem; color: #d4d4d8; }
        .content p { margin-bottom: 1rem; line-height: 1.75; color: #a1a1aa; }
        .content a { color: #3b82f6; text-decoration: underline; }
        .content a:hover { color: #60a5fa; }
        .content ul { list-style: disc; padding-left: 1.5rem; margin-bottom: 1rem; color: #a1a1aa; }
        .content ul li { margin-bottom: 0.25rem; }
        .content table { width: 100%; border-collapse: collapse; margin-bottom: 1.5rem; }
        .content th { text-align: left; padding: 0.75rem; border-bottom: 2px solid #27272a; color: #e4e4e7; font-weight: 600; }
        .content td { padding: 0.75rem; border-bottom: 1px solid #1f1f23; color: #a1a1aa; }
        .content code:not(pre code) { background: #1f1f23; padding: 0.15rem 0.4rem; border-radius: 0.25rem; font-size: 0.875rem; color: #10b981; }
        .content pre { background: #0f0f12; border: 1px solid #27272a; border-radius: 0.75rem; padding: 1.25rem; overflow-x: auto; margin-bottom: 1.5rem; }
        .content pre code { color: #d4d4d8; font-size: 0.875rem; line-height: 1.6; }
        .search-box { background: #18181b; border: 1px solid #27272a; }
        .search-box:focus { border-color: #10b981; outline: none; }
    </style>
</head>
<body class="bg-zinc-950 text-white min-h-screen antialiased">

    <!-- Nav -->
    <nav class="fixed top-0 w-full z-50 bg-zinc-950/80 backdrop-blur-xl border-b border-zinc-800/50">
        <div class="max-w-7xl mx-auto px-6 h-16 flex items-center justify-between">
            <a href="/" class="flex items-center gap-2">
                <div class="w-8 h-8 rounded-lg bg-emerald-500 flex items-center justify-center font-bold text-sm">G</div>
                <span class="font-semibold text-lg">GoW</span>
            </a>
            <div class="flex items-center gap-6 text-sm text-zinc-400">
                <a href="/docs" class="text-emerald-400 font-medium">Docs</a>
                <a href="#" class="hover:text-white transition">GitHub</a>
                <a href="/login" class="px-4 py-2 bg-white text-zinc-950 font-medium rounded-lg hover:bg-zinc-200 transition">Login</a>
            </div>
        </div>
    </nav>

    <div class="flex pt-16">
        <!-- Sidebar -->
        <aside class="sidebar fixed w-64 h-[calc(100vh-4rem)] overflow-y-auto border-r border-zinc-800/50 p-6 hidden lg:block">
            <input type="text" placeholder="Search docs..." class="search-box w-full px-4 py-2.5 rounded-lg text-sm mb-6" id="searchInput">

            <div class="space-y-1">
                <div class="text-xs font-semibold text-zinc-500 uppercase tracking-wider mb-3">Getting Started</div>
