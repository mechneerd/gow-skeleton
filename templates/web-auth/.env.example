APP_NAME={{ .AppName }}
APP_ENV=local
APP_KEY=base64:CHANGE_ME
APP_DEBUG=true
APP_URL=http://localhost:8080

DB_CONNECTION={{ .DatabaseDriver }}
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE={{ .AppName }}
DB_USERNAME=root
DB_PASSWORD=

# Authentication
AUTH_DEFAULT_GUARD=web
SANCTUM_STATEFUL_DOMAINS=localhost:8080

SESSION_DRIVER=file
QUEUE_CONNECTION=sync

# Mail (for password reset, etc.)
MAIL_MAILER=smtp
MAIL_HOST=127.0.0.1
MAIL_PORT=1025
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=
MAIL_FROM_ADDRESS="hello@{{ .AppName }}.com"
MAIL_FROM_NAME="{{ .AppName }}"
